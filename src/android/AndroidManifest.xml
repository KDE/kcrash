<manifest xmlns:android="http://schemas.android.com/apk/res/android" xmlns:tools="http://schemas.android.com/tools" package="org.kde.crash">
    <application>
        <!-- disable automatic Sentry initialization, we do that ourselves on demand -->
        <meta-data android:name="io.sentry.auto-init" android:value="false"/>
        <provider android:name="io.sentry.android.core.SentryInitProvider" android:authorities="${applicationId}.SentryInitProvider" tools:node="remove"/>
        <provider android:name="io.sentry.android.core.SentryPerformanceProvider" android:authorities="${applicationId}.SentryPerformanceProvider" tools:node="remove"/>
    </application>
</manifest>
